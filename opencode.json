{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": {
        "BROWSER": "chromium"
      }
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true,
      "env": {
        "CONTEXT7_API_KEY": "ctx7sk-63db4827-4218-4cf9-a98f-17dc3eb7869a"
      }
    },
    "searxng": {
      "type": "local",
      "command": ["npx", "-y", "mcp-searxng"],
      "enabled": true,
      "env": {
        "SEARXNG_URL": "https://searx.be"
      }
    }
  }
}
